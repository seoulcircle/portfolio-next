{
  "compilerOptions": {
    "baseUrl": "apps/portfolio",

    "paths": {
      "@/*": ["/*"],
      "@assets/*": ["/assets/*"],
      "@hooks/*": ["../../packages/hooks/*"],
      "@ui/*": ["../../packages/ui/*"],
      "@styles/*": ["../../packages/styles/*"],
      "@animations/*": ["../../packages/animations/*"],
      "@components/*": ["../../packages/components/*"]
    },

    "strict": true,
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node16",
    "module": "node16",
    "target": "esnext",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
